DATABASE_URL="postgresql://user@localhost:5432/grass_erp?schema=public"
JWT_SECRET="change-this-to-a-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# System owner account (required for seeding)
SYSTEM_OWNER_EMAIL=owner@example.com
SYSTEM_OWNER_PASSWORD=change-me-securely
SYSTEM_OWNER_NAME=System Owner

# Legacy admin account (optional — only created if both EMAIL and PASSWORD are set)
LEGACY_ADMIN_EMAIL=admin@example.com
LEGACY_ADMIN_PASSWORD=change-me-securely
LEGACY_ADMIN_NAME=Legacy Admin
