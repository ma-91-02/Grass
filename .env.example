# GRASS ERP — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

DATABASE_URL="postgresql://user@localhost:5432/grass_erp?schema=public"
JWT_SECRET="change-this-to-a-random-secret"  # Generate: openssl rand -hex 32
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# System owner account (required for seeding)
SYSTEM_OWNER_EMAIL=owner@example.com
SYSTEM_OWNER_PASSWORD=change-me-securely  # Min 12 chars, mixed case + number
SYSTEM_OWNER_NAME=محمد الزرفي

# Optional one-time cleanup only:
# COMPROMISED_LEGACY_ADMIN_EMAIL=

# Rate limiting (optional, defaults apply)
# RATE_LIMIT_MAX_ATTEMPTS=5
# RATE_LIMIT_WINDOW_MS=900000
