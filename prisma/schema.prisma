generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  USD
  IQD
}

enum CustomerTypeEnum {
  INDIVIDUAL
  MARKET
  WHOLESALE
  AGENT
  ONLINE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  phone        String?
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?

  roles                   UserRole[]
  auditLogs               AuditLog[]
  createdCustomers        Customer[]           @relation("CustomerCreatedBy")
  createdSuppliers        Supplier[]           @relation("SupplierCreatedBy")
  createdStockTransfers   StockTransfer[]
  createdStockAdjustments StockAdjustment[]
  collectionsCreated      CustomerCollection[] @relation("CollectionCreatedBy")
  createdSalesReturns     SalesReturn[]        @relation("SalesReturnCreatedBy")
  supplierPaymentsCreated SupplierPayment[]    @relation("SupplierPaymentCreatedBy")
  employeesCreated        Employee[]           @relation("EmployeeCreatedBy")
  managedProjects         Project[]            @relation("ProjectManager")
  createdProjects         Project[]            @relation("ProjectCreatedBy")
  updatedProjects         Project[]            @relation("ProjectUpdatedBy")
  createdTasks            ProjectTask[]        @relation("TaskCreatedBy")
  updatedTasks            ProjectTask[]        @relation("TaskUpdatedBy")

  @@index([companyId])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  module      String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum PeriodStatus {
  FUTURE
  OPEN
  CLOSING_IN_PROGRESS
  SOFT_CLOSED
  HARD_CLOSED
  ARCHIVED
}

enum PostingOperationStatus {
  REQUESTED
  LOCK_ACQUIRED
  VALIDATING
  BUILDING_JOURNAL
  PERSISTING
  COMMITTED
  FAILED_VALIDATION
  FAILED_ROLLED_BACK
  RETRY_PENDING
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum ProjectTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum MovementType {
  OPENING_BALANCE
  IN
  OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_OUT
  TRANSFER_IN
  RETURN_IN
  RETURN_OUT
}

enum MovementStatus {
  DRAFT
  POSTED
  CANCELLED
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String
  entity       String
  entityId     String?
  details      Json?
  beforeJson   Json?
  afterJson    Json?
  metadataJson Json?
  requestId    String?
  ipAddress    String?
  userAgent    String?
  companyId    String?
  branchId     String?
  createdAt    DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([requestId])
}

model CustomerCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customers Customer[]
}

model Customer {
  id                 String            @id @default(cuid())
  companyId          String?
  company            Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name               String
  code               String
  phone              String?
  whatsapp           String?
  email              String?
  address            String?
  governorate        String?
  customerType       CustomerTypeEnum  @default(INDIVIDUAL)
  customerCategoryId String?
  customerCategory   CustomerCategory? @relation(fields: [customerCategoryId], references: [id])
  isActive           Boolean           @default(true)
  notes              String?
  creditLimit        Decimal?          @default(0)
  currentBalance     Decimal?          @default(0)
  currency           Currency          @default(IQD)
  createdById        String?
  createdBy          User?             @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  accounts     CustomerAccount[]
  invoices     Invoice[]
  collections  CustomerCollection[]
  salesReturns SalesReturn[]

  @@unique([companyId, code])
  @@index([companyId])
}

model CustomerAccount {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  currency   Currency @default(IQD)
  balance    Decimal  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, currency])
}

model Supplier {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name        String
  code        String
  phone       String?
  address     String?
  governorate String?
  notes       String?
  isActive    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("SupplierCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts         SupplierAccount[]
  purchaseInvoices PurchaseInvoice[]
  supplierPayments SupplierPayment[]

  @@unique([companyId, code])
  @@index([companyId])
}

model SupplierAccount {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  currency   Currency @default(IQD)
  balance    Decimal  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([supplierId, currency])
}

model ProductCategory {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name        String
  code        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@unique([companyId, code])
  @@index([companyId])
}

model ProductPackaging {
  id              String   @id @default(cuid())
  name            String   @unique
  piecesPerCarton Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Unit {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name      String
  code      String
  symbol    String?
  type      String   @default("PIECE")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Product {
  id               String           @id @default(cuid())
  companyId        String?
  company          Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  name             String
  code             String
  sku              String?
  barcode          String?
  categoryId       String?
  category         ProductCategory? @relation(fields: [categoryId], references: [id])
  unitId           String?
  unit             Unit?            @relation(fields: [unitId], references: [id])
  packaging        String           @default("قطعة")
  piecesPerCarton  Int              @default(0)
  purchasePrice    Decimal          @default(0)
  purchaseCurrency Currency         @default(IQD)
  productType      String           @default("STOCK")
  description      String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  prices               ProductPrice[]
  invoiceItems         InvoiceItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  salesReturnLines     SalesReturnLine[]
  stockMovements       StockMovement[]
  stockBalances        StockBalance[]
  transferLines        StockTransferLine[]
  adjustmentLines      StockAdjustmentLine[]

  @@unique([companyId, code])
  @@unique([companyId, barcode])
  @@index([companyId])
  @@index([categoryId])
  @@index([unitId])
}

model ProductPrice {
  id           String           @id @default(cuid())
  productId    String
  product      Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerType CustomerTypeEnum
  price        Decimal
  currency     Currency         @default(IQD)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([productId, customerType])
}

model Warehouse {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  name      String
  code      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices         Invoice[]
  purchaseInvoices PurchaseInvoice[]
  stockMovements   StockMovement[]
  stockBalances    StockBalance[]
  transfersFrom    StockTransfer[]   @relation("TransferFrom")
  transfersTo      StockTransfer[]   @relation("TransferTo")
  stockAdjustments StockAdjustment[]
  salesReturns     SalesReturn[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
}

model ExchangeRate {
  id          String   @id @default(cuid())
  usdToIqd    Decimal
  date        DateTime @default(now())
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  invoices Invoice[]
}

model Invoice {
  id                   String           @id @default(cuid())
  companyId            String?
  company              Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  invoiceNumber        String
  customerId           String?
  customer             Customer?        @relation(fields: [customerId], references: [id])
  customerType         CustomerTypeEnum @default(INDIVIDUAL)
  warehouseId          String?
  warehouse            Warehouse?       @relation(fields: [warehouseId], references: [id])
  exchangeRateId       String?
  exchangeRate         ExchangeRate?    @relation(fields: [exchangeRateId], references: [id])
  currency             Currency         @default(IQD)
  exchangeRateValue    Decimal          @default(0)
  exchangeRateSnapshot Decimal?
  paymentType          String           @default("CASH")
  paymentAccountId     String?
  paymentAccount       PaymentAccount?  @relation(fields: [paymentAccountId], references: [id])
  totalBeforeTax       Decimal          @default(0)
  taxAmount            Decimal          @default(0)
  discountAmount       Decimal          @default(0)
  discountPercent      Decimal?         @default(0)
  totalAfterTax        Decimal          @default(0)
  totalInUsd           Decimal?         @default(0)
  paid                 Decimal          @default(0)
  remaining            Decimal          @default(0)
  invoiceDate          DateTime         @default(now())
  status               String           @default("DRAFT")
  postedAt             DateTime?
  postedById           String?
  journalEntryId       String?
  notes                String?
  createdById          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  items        InvoiceItem[]
  payments     Payment[]
  collections  CustomerCollection[]
  salesReturns SalesReturn[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([warehouseId])
  @@index([customerId])
  @@index([status])
}

model InvoiceItem {
  id                  String   @id @default(cuid())
  invoiceId           String
  invoice             Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId           String
  product             Product  @relation(fields: [productId], references: [id])
  quantity            Int      @default(1)
  unitPrice           Decimal  @default(0)
  discountPercent     Decimal? @default(0)
  discountAmount      Decimal? @default(0)
  totalPrice          Decimal  @default(0)
  lineTotal           Decimal  @default(0)
  productNameSnapshot String?
  productCodeSnapshot String?
  averageCostSnapshot Decimal?
  stockMovementId     String?
  notes               String?
  createdAt           DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Decimal
  paymentDate DateTime @default(now())
  method      String   @default("CASH")
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
}

model SalesReturn {
  id                 String    @id @default(cuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  returnNumber       String
  originalInvoiceId  String
  originalInvoice    Invoice   @relation(fields: [originalInvoiceId], references: [id], onDelete: Restrict)
  customerId         String
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  warehouseId        String
  warehouse          Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  returnDate         DateTime  @default(now())
  currency           Currency  @default(IQD)
  totalAmount        Decimal   @default(0)
  totalCogs          Decimal   @default(0)
  status             String    @default("DRAFT")
  postedAt           DateTime?
  postedById         String?
  journalEntryId     String?
  cogsJournalEntryId String?
  notes              String?
  createdById        String?
  createdBy          User?     @relation("SalesReturnCreatedBy", fields: [createdById], references: [id])
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  lines SalesReturnLine[]

  @@unique([companyId, returnNumber])
  @@index([companyId])
  @@index([originalInvoiceId])
  @@index([customerId])
  @@index([status])
}

model SalesReturnLine {
  id                    String      @id @default(cuid())
  salesReturnId         String
  salesReturn           SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  originalInvoiceItemId String
  productId             String
  product               Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity              Int         @default(0)
  unitPriceSnapshot     Decimal     @default(0)
  averageCostSnapshot   Decimal     @default(0)
  lineTotal             Decimal     @default(0)
  stockMovementId       String?
  notes                 String?
  createdAt             DateTime    @default(now())

  @@index([salesReturnId])
  @@index([productId])
}

model CustomerCollection {
  id               String          @id @default(cuid())
  companyId        String?
  company          Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customerId       String
  customer         Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoiceId        String?
  invoice          Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentAccountId String?
  paymentAccount   PaymentAccount? @relation(fields: [paymentAccountId], references: [id], onDelete: SetNull)
  amount           Decimal
  currency         Currency        @default(IQD)
  collectionDate   DateTime        @default(now())
  journalEntryId   String?
  journalEntry     JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  notes            String?
  createdById      String?
  createdBy        User?           @relation("CollectionCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([companyId])
  @@index([customerId])
  @@index([invoiceId])
}

model SupplierPayment {
  id                String           @id @default(cuid())
  companyId         String?
  company           Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  supplierId        String
  supplier          Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: SetNull)
  paymentAccountId  String?
  paymentAccount    PaymentAccount?  @relation(fields: [paymentAccountId], references: [id], onDelete: SetNull)
  amount            Decimal
  currency          Currency         @default(IQD)
  paymentDate       DateTime         @default(now())
  journalEntryId    String?
  journalEntry      JournalEntry?    @relation(fields: [journalEntryId], references: [id])
  notes             String?
  createdById       String?
  createdBy         User?            @relation("SupplierPaymentCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId])
  @@index([supplierId])
  @@index([purchaseInvoiceId])
}

model PurchaseInvoice {
  id                    String          @id @default(cuid())
  companyId             String?
  company               Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  invoiceNumber         String          @unique
  supplierInvoiceNumber String?
  purchaseDate          DateTime        @default(now())
  currency              Currency        @default(IQD)
  exchangeRateValue     Decimal         @default(0)
  supplierId            String?
  supplier              Supplier?       @relation(fields: [supplierId], references: [id])
  warehouseId           String?
  warehouse             Warehouse?      @relation(fields: [warehouseId], references: [id])
  notes                 String?
  subtotal              Decimal         @default(0)
  totalExpenses         Decimal         @default(0)
  totalCost             Decimal         @default(0)
  paymentMethod         String          @default("CASH")
  paid                  Decimal         @default(0)
  remaining             Decimal         @default(0)
  paymentAccountId      String?
  paymentAccount        PaymentAccount? @relation(fields: [paymentAccountId], references: [id])
  status                String          @default("DRAFT")
  postedAt              DateTime?
  postedById            String?
  journalEntryId        String?         @unique
  journalEntry          JournalEntry?   @relation("PurchaseInvoiceJournal", fields: [journalEntryId], references: [id])
  createdById           String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  items            PurchaseInvoiceItem[]
  expenses         PurchaseExpense[]
  supplierPayments SupplierPayment[]

  @@index([companyId])
}

model PurchaseInvoiceItem {
  id                String          @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  productId         String?
  product           Product?        @relation(fields: [productId], references: [id])
  productName       String
  productCode       String
  quantity          Int             @default(1)
  purchasePrice     Decimal         @default(0)
  productionDate    DateTime?
  expiryDate        DateTime?
  totalPrice        Decimal         @default(0)
  expenseShare      Decimal         @default(0)
  finalCost         Decimal         @default(0)
  unitFinalCost     Decimal         @default(0)

  @@index([purchaseInvoiceId])
}

model PurchaseExpense {
  id                      String          @id @default(cuid())
  purchaseInvoiceId       String
  purchaseInvoice         PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  name                    String
  amount                  Decimal         @default(0)
  currency                Currency        @default(IQD)
  amountInInvoiceCurrency Decimal         @default(0)

  @@index([purchaseInvoiceId])
}

model PaymentAccount {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @default("CASH")
  currency  Currency @default(IQD)
  balance   Decimal  @default(0)
  isActive  Boolean  @default(true)
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseInvoices    PurchaseInvoice[]
  invoices            Invoice[]
  customerCollections CustomerCollection[]
  supplierPayments    SupplierPayment[]
}

model StockMovement {
  id            String         @id @default(cuid())
  companyId     String?
  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  productId     String
  product       Product        @relation(fields: [productId], references: [id])
  warehouseId   String?
  warehouse     Warehouse?     @relation(fields: [warehouseId], references: [id])
  movementType  MovementType
  quantity      Int
  unitCost      Decimal?       @default(0)
  currency      Currency       @default(IQD)
  movementDate  DateTime       @default(now())
  referenceType String?
  referenceId   String?
  reason        String?
  notes         String?
  status        MovementStatus @default(DRAFT)
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
  @@index([referenceType, referenceId])
  @@index([status])
  @@index([movementDate])
}

model StockBalance {
  id               String    @id @default(cuid())
  companyId        String
  productId        String
  product          Product   @relation(fields: [productId], references: [id])
  warehouseId      String
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  quantityOnHand   Int       @default(0)
  reservedQuantity Int       @default(0)
  unitCost         Decimal   @default(0)
  averageCost      Decimal   @default(0)
  totalValue       Decimal   @default(0)
  currency         Currency  @default(IQD)
  lastMovementId   String?
  updatedAt        DateTime  @updatedAt

  @@unique([companyId, productId, warehouseId])
  @@index([companyId])
  @@index([productId])
  @@index([warehouseId])
}

model StockTransfer {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouseId String
  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  transferNumber  String
  status          MovementStatus @default(DRAFT)
  transferDate    DateTime       @default(now())
  notes           String?
  createdById     String?
  createdBy       User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  lines StockTransferLine[]

  @@unique([companyId, transferNumber])
  @@index([companyId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([status])
  @@index([transferDate])
}

model StockTransferLine {
  id         String        @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity   Int
  unitCost   Decimal       @default(0)
  currency   Currency      @default(IQD)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([transferId])
  @@index([productId])
}

model StockAdjustment {
  id               String         @id @default(cuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouseId      String
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id])
  adjustmentNumber String
  adjustmentType   String // IN or OUT
  status           MovementStatus @default(DRAFT)
  adjustmentDate   DateTime       @default(now())
  reason           String?
  notes            String?
  createdById      String?
  createdBy        User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  lines StockAdjustmentLine[]

  @@unique([companyId, adjustmentNumber])
  @@index([companyId])
  @@index([warehouseId])
  @@index([status])
  @@index([adjustmentDate])
}

model StockAdjustmentLine {
  id           String          @id @default(cuid())
  adjustmentId String
  adjustment   StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  quantity     Int
  unitCost     Decimal         @default(0)
  currency     Currency        @default(IQD)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([adjustmentId])
  @@index([productId])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  taxId     String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches            Branch[]
  accounts            Account[]
  fiscalPeriods       FiscalPeriod[]
  journalEntries      JournalEntry[]
  users               User[]
  purchaseInvoices    PurchaseInvoice[]
  invoices            Invoice[]
  productCategories   ProductCategory[]
  products            Product[]
  units               Unit[]
  warehouses          Warehouse[]
  customers           Customer[]
  suppliers           Supplier[]
  customerCollections CustomerCollection[]
  supplierPayments    SupplierPayment[]
  salesReturns        SalesReturn[]
  stockMovements      StockMovement[]
  stockTransfers      StockTransfer[]
  stockAdjustments    StockAdjustment[]
  employees           Employee[]
  projects            Project[]
  projectTasks        ProjectTask[]

  @@index([code])
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fiscalPeriods  FiscalPeriod[]
  journalEntries JournalEntry[]
  warehouses     Warehouse[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Employee {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  code        String
  name        String
  phone       String?
  email       String?
  address     String?
  position    String?
  notes       String?
  isActive    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("EmployeeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
}

model Project {
  id            String          @id @default(cuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  code          String
  name          String
  description   String?
  status        ProjectStatus   @default(PLANNED)
  priority      ProjectPriority @default(MEDIUM)
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  managerUserId String?
  managerUser   User?           @relation("ProjectManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?           @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById   String?
  updatedBy     User?           @relation("ProjectUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tasks           ProjectTask[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([companyId, status])
  @@index([managerUserId])
}

model ProjectTask {
  id            String              @id @default(cuid())
  companyId     String
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  projectId     String
  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code          String
  title         String
  description   String?
  status        ProjectTaskStatus   @default(TODO)
  priority      ProjectTaskPriority @default(MEDIUM)
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  parentTaskId  String?
  parentTask    ProjectTask?        @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  childTasks    ProjectTask[]       @relation("TaskHierarchy")
  createdById   String?
  createdBy     User?               @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById   String?
  updatedBy     User?               @relation("TaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([projectId, code])
  @@index([companyId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
  @@index([parentTaskId])
}

model FiscalPeriod {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?      @relation(fields: [branchId], references: [id])
  name      String
  startDate DateTime
  endDate   DateTime
  status    PeriodStatus @default(FUTURE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  journalEntries JournalEntry[]

  @@unique([companyId, branchId, name])
  @@index([companyId, status])
  @@index([companyId, startDate, endDate])
  @@index([companyId, branchId])
}

model Account {
  id                 String        @id @default(cuid())
  companyId          String
  company            Company       @relation(fields: [companyId], references: [id])
  code               String
  name               String
  parentId           String?
  parent             Account?      @relation("AccountTree", fields: [parentId], references: [id])
  children           Account[]     @relation("AccountTree")
  type               String // ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  subtype            String?
  normalBalance      NormalBalance @default(DEBIT)
  currency           Currency      @default(IQD)
  level              Int           @default(0)
  isPosting          Boolean       @default(true)
  isSystem           Boolean       @default(false)
  isProtected        Boolean       @default(false)
  isActive           Boolean       @default(true)
  allowManualJournal Boolean       @default(true)
  description        String?
  createdById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  journalLines    JournalLine[]
  paymentAccounts PaymentAccount[]

  @@unique([companyId, code])
  @@index([companyId, parentId])
  @@index([companyId, type])
  @@index([companyId, isActive])
}

model JournalEntry {
  id                   String             @id @default(cuid())
  companyId            String
  company              Company            @relation(fields: [companyId], references: [id])
  branchId             String?
  branch               Branch?            @relation(fields: [branchId], references: [id])
  fiscalPeriodId       String?
  fiscalPeriod         FiscalPeriod?      @relation(fields: [fiscalPeriodId], references: [id])
  entryNumber          String
  entryDate            DateTime           @default(now())
  currency             Currency           @default(IQD)
  exchangeRateSnapshot Decimal            @default(1)
  description          String?
  sourceType           String?
  sourceId             String?
  status               JournalEntryStatus @default(DRAFT)
  postedAt             DateTime?
  reversalEntryId      String?            @unique
  reversalEntry        JournalEntry?      @relation("JournalReversal", fields: [reversalEntryId], references: [id])
  reversedEntries      JournalEntry[]     @relation("JournalReversal")
  reversedAt           DateTime?
  createdById          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  lines               JournalLine[]
  postingOperations   PostingOperation[]
  customerCollections CustomerCollection[]
  supplierPayments    SupplierPayment[]
  purchaseInvoices    PurchaseInvoice[]    @relation("PurchaseInvoiceJournal")

  @@unique([companyId, entryNumber])
  @@index([companyId, fiscalPeriodId])
  @@index([companyId, status])
  @@index([companyId, sourceType, sourceId])
  @@index([companyId, branchId])
  @@index([companyId, entryDate])
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0)
  credit         Decimal      @default(0)
  description    String?
  createdAt      DateTime     @default(now())

  @@index([journalEntryId])
  @@index([accountId])
}

model PostingOperation {
  id             String                 @id @default(cuid())
  idempotencyKey String                 @unique
  hash           String?
  sourceType     String
  sourceId       String
  journalEntryId String?
  journalEntry   JournalEntry?          @relation(fields: [journalEntryId], references: [id])
  status         PostingOperationStatus @default(REQUESTED)
  result         Json?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([sourceType, sourceId])
  @@index([status])
  @@index([idempotencyKey])
}
