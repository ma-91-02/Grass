generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Currency {
  USD
  IQD
}

enum CustomerTypeEnum {
  INDIVIDUAL
  MARKET
  WHOLESALE
  AGENT
  ONLINE
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  passwordHash  String
  isActive      Boolean      @default(true)
  phone         String?
  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     String?

  roles         UserRole[]
  auditLogs     AuditLog[]
  createdCustomers Customer[] @relation("CustomerCreatedBy")
  createdSuppliers Supplier[] @relation("SupplierCreatedBy")

  @@index([companyId])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  module      String
  description String?
  createdAt   DateTime @default(now())

  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum PeriodStatus {
  FUTURE
  OPEN
  CLOSING_IN_PROGRESS
  SOFT_CLOSED
  HARD_CLOSED
  ARCHIVED
}

enum PostingOperationStatus {
  REQUESTED
  LOCK_ACQUIRED
  VALIDATING
  BUILDING_JOURNAL
  PERSISTING
  COMMITTED
  FAILED_VALIDATION
  FAILED_ROLLED_BACK
  RETRY_PENDING
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

model AuditLog {
  id           String                     @id @default(cuid())
  userId       String
  user         User                       @relation(fields: [userId], references: [id])
  action       String
  entity       String
  entityId     String?
  details      Json?
  beforeJson   Json?
  afterJson    Json?
  metadataJson Json?
  requestId    String?
  ipAddress    String?
  userAgent    String?
  companyId    String?
  branchId     String?
  createdAt    DateTime                   @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([requestId])
}

model CustomerCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  customers   Customer[]
}

model Customer {
  id                  String           @id @default(cuid())
  name                String
  code                String           @unique
  phone               String?
  whatsapp            String?
  address             String?
  governorate         String?
  customerType        CustomerTypeEnum @default(INDIVIDUAL)
  customerCategoryId  String?
  customerCategory    CustomerCategory? @relation(fields: [customerCategoryId], references: [id])
  isActive            Boolean          @default(true)
  notes               String?
  createdById         String?
  createdBy           User?            @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  accounts            CustomerAccount[]
  invoices            Invoice[]
}

model CustomerAccount {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  currency   Currency @default(IQD)
  balance    Decimal  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, currency])
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  phone         String?
  address       String?
  governorate   String?
  notes         String?
  isActive      Boolean  @default(true)
  createdById   String?
  createdBy     User?    @relation("SupplierCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts      SupplierAccount[]
  purchaseInvoices PurchaseInvoice[]
}

model SupplierAccount {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  currency   Currency @default(IQD)
  balance    Decimal  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([supplierId, currency])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

model ProductPackaging {
  id              String    @id @default(cuid())
  name            String    @unique
  piecesPerCarton Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Product {
  id               String     @id @default(cuid())
  name             String
  code             String     @unique
  barcode          String?    @unique
  categoryId       String?
  category         ProductCategory? @relation(fields: [categoryId], references: [id])
  packaging        String     @default("قطعة")
  piecesPerCarton  Int        @default(0)
  unit             String     @default("قطعة")
  purchasePrice    Decimal    @default(0)
  purchaseCurrency Currency   @default(IQD)
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  prices           ProductPrice[]
  invoiceItems         InvoiceItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]
  stockMovements       StockMovement[]
}

model ProductPrice {
  id             String           @id @default(cuid())
  productId      String
  product        Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerType   CustomerTypeEnum
  price          Decimal
  currency       Currency         @default(IQD)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([productId, customerType])
}

model Warehouse {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  address     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  invoices    Invoice[]
  purchaseInvoices PurchaseInvoice[]
  stockMovements   StockMovement[]
}

model ExchangeRate {
  id            String   @id @default(cuid())
  usdToIqd      Decimal
  date          DateTime @default(now())
  note          String?
  createdById   String?
  createdAt     DateTime @default(now())

  invoices      Invoice[]
}

model Invoice {
  id                 String           @id @default(cuid())
  invoiceNumber      String           @unique
  customerId         String?
  customer           Customer?        @relation(fields: [customerId], references: [id])
  customerType       CustomerTypeEnum @default(INDIVIDUAL)
  warehouseId        String?
  warehouse          Warehouse?       @relation(fields: [warehouseId], references: [id])
  exchangeRateId     String?
  exchangeRate       ExchangeRate?    @relation(fields: [exchangeRateId], references: [id])
  exchangeRateValue  Decimal          @default(0)
  totalBeforeTax     Decimal          @default(0)
  taxAmount          Decimal          @default(0)
  discountAmount     Decimal          @default(0)
  totalAfterTax      Decimal          @default(0)
  totalInUsd         Decimal?         @default(0)
  status             String           @default("DRAFT")
  notes              String?
  createdById        String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  items              InvoiceItem[]
  payments           Payment[]
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0)
  totalPrice  Decimal @default(0)
  createdAt   DateTime @default(now())
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Decimal
  paymentDate DateTime @default(now())
  method      String   @default("CASH")
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
}

model PurchaseInvoice {
  id                     String               @id @default(cuid())
  invoiceNumber          String               @unique
  supplierInvoiceNumber  String?
  purchaseDate           DateTime             @default(now())
  currency               Currency             @default(IQD)
  exchangeRateValue      Decimal              @default(0)
  supplierId             String?
  supplier               Supplier?            @relation(fields: [supplierId], references: [id])
  warehouseId            String?
  warehouse              Warehouse?           @relation(fields: [warehouseId], references: [id])
  notes                  String?
  subtotal               Decimal              @default(0)
  totalExpenses          Decimal              @default(0)
  totalCost              Decimal              @default(0)
  paymentMethod          String               @default("CASH")
  paid                   Decimal              @default(0)
  remaining              Decimal              @default(0)
  paymentAccountId       String?
  paymentAccount         PaymentAccount?      @relation(fields: [paymentAccountId], references: [id])
  status                 String               @default("COMPLETED")
  createdById            String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  items                  PurchaseInvoiceItem[]
  expenses               PurchaseExpense[]
}

model PurchaseInvoiceItem {
  id               String          @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice  PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product?        @relation(fields: [productId], references: [id])
  productName      String
  productCode      String
  quantity         Int             @default(1)
  purchasePrice    Decimal         @default(0)
  productionDate   DateTime?
  expiryDate       DateTime?
  totalPrice       Decimal         @default(0)
  expenseShare     Decimal         @default(0)
  finalCost        Decimal         @default(0)
  unitFinalCost    Decimal         @default(0)

  @@index([purchaseInvoiceId])
}

model PurchaseExpense {
  id               String          @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice  PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  name             String
  amount           Decimal         @default(0)
  currency         Currency        @default(IQD)
  amountInInvoiceCurrency Decimal   @default(0)

  @@index([purchaseInvoiceId])
}

model PaymentAccount {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @default("CASH")
  currency  Currency @default(IQD)
  balance   Decimal  @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseInvoices PurchaseInvoice[]
}

model StockMovement {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id])
  type          String   @default("IN")
  quantity      Int      @default(0)
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime @default(now())

  @@index([productId])
  @@index([warehouseId])
  @@index([referenceType, referenceId])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  taxId     String?
  address   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches      Branch[]
  accounts      Account[]
  fiscalPeriods FiscalPeriod[]
  journalEntries JournalEntry[]
  users         User[]

  @@index([code])
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fiscalPeriods  FiscalPeriod[]
  journalEntries JournalEntry[]

  @@unique([companyId, code])
  @@index([companyId])
}

model FiscalPeriod {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id])
  branchId  String?
  branch    Branch?      @relation(fields: [branchId], references: [id])
  name      String
  startDate DateTime
  endDate   DateTime
  status    PeriodStatus @default(FUTURE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  journalEntries JournalEntry[]

  @@unique([companyId, branchId, name])
  @@index([companyId, status])
  @@index([companyId, startDate, endDate])
  @@index([companyId, branchId])
}

model Account {
  id                 String       @id @default(cuid())
  companyId          String
  company            Company      @relation(fields: [companyId], references: [id])
  code               String
  name               String
  parentId           String?
  parent             Account?     @relation("AccountTree", fields: [parentId], references: [id])
  children           Account[]    @relation("AccountTree")
  type               String       // ASSET, LIABILITY, EQUITY, INCOME, EXPENSE
  subtype            String?
  normalBalance      NormalBalance @default(DEBIT)
  currency           Currency     @default(IQD)
  level              Int          @default(0)
  isPosting          Boolean      @default(true)
  isSystem           Boolean      @default(false)
  isProtected        Boolean      @default(false)
  isActive           Boolean      @default(true)
  allowManualJournal Boolean      @default(true)
  description        String?
  createdById        String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  journalLines JournalLine[]

  @@unique([companyId, code])
  @@index([companyId, parentId])
  @@index([companyId, type])
  @@index([companyId, isActive])
}

model JournalEntry {
  id                   String             @id @default(cuid())
  companyId            String
  company              Company            @relation(fields: [companyId], references: [id])
  branchId             String?
  branch               Branch?            @relation(fields: [branchId], references: [id])
  fiscalPeriodId       String?
  fiscalPeriod         FiscalPeriod?      @relation(fields: [fiscalPeriodId], references: [id])
  entryNumber          String
  entryDate            DateTime           @default(now())
  currency             Currency           @default(IQD)
  exchangeRateSnapshot Decimal            @default(1)
  description          String?
  sourceType           String?
  sourceId             String?
  status               JournalEntryStatus @default(DRAFT)
  postedAt             DateTime?
  createdById          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  lines             JournalLine[]
  postingOperations PostingOperation[]

  @@unique([companyId, entryNumber])
  @@index([companyId, fiscalPeriodId])
  @@index([companyId, status])
  @@index([companyId, sourceType, sourceId])
  @@index([companyId, branchId])
  @@index([companyId, entryDate])
}

model JournalLine {
  id             String       @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0)
  credit         Decimal      @default(0)
  description    String?
  createdAt      DateTime     @default(now())

  @@index([journalEntryId])
  @@index([accountId])
}

model PostingOperation {
  id              String                 @id @default(cuid())
  idempotencyKey  String                 @unique
  hash            String?
  sourceType      String
  sourceId        String
  journalEntryId  String?
  journalEntry    JournalEntry?           @relation(fields: [journalEntryId], references: [id])
  status          PostingOperationStatus  @default(REQUESTED)
  result          Json?
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([sourceType, sourceId])
  @@index([status])
  @@index([idempotencyKey])
}
